{
  "_version": "1.84.0",
  "sap.app": {
    "id": "purchase",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.24.0",
      "toolsId": "227ab285-b0f1-4bb7-bec9-8c8f2cac2221"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/po/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.147.2",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "purchase.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "purchase.view",
        "async": true,
        "viewPath": "purchase.view"
      },
      "routes": [
        {
          "name": "RoutePurchase",
          "pattern": ":?query:",
          "target": [
            "TargetPurchase"
          ]
        },
        {
          "name": "RouteOrdersResult",
          "pattern": "ordersResult",
          "target": [
            "TargetOrdersResult"
          ]
        },
        {
          "name": "RouteFinancialDashboard",
          "pattern": "Finance",
          "target": [
            "TargetFinancialDashboard"
          ]
        }

      ],
      "targets": {
        "TargetPurchase": {
          "id": "Purchase",
          "name": "Purchase"
        },
        "TargetOrdersResult": {
          "id": "OrdersResult",
          "name": "OrdersResult"
        },
         "TargetFinancialDashboard": {
          "id": "FinancialDashboard",
          "name": "FinancialDashboard"
        }
      }
    },
    "rootView": {
      "viewName": "purchase.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
