<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="poDialog" title="Purchase Order Items" stretch="false">

        <Table id="_IDGenTable2" items="{items>/items}">

            <columns>
                <Column id="_IDGenColumn2"><Text id="_IDGenText4" text="Material"/></Column>
                <Column id="_IDGenColumn3"><Text id="_IDGenText5" text="Quantity"/></Column>
                <Column id="_IDGenColumn4"><Text id="_IDGenText6" text="Unit Price"/></Column>
                <Column id="_IDGenColumn478"><Text id="_IDGenText612" text="Gross amount"/></Column>     
             </columns>

            <items>
                <ColumnListItem id="_IDGenColumnListItem1">
                    <cells>
                        <Text id="_IDGenText7" text="{items>PurchaseOrderItemText}"/>
                        <Text id="_IDGenText8" text="{items>OrderQuantity}"/>
                        <Text id="_IDGenText9" text="{items>NetPriceAmount}"/>
                        <Text id="_IDGenText91" text="{items>GrossAmount}"/>
                    </cells>
                </ColumnListItem>
            </items>

        </Table>

       

    <VBox id="_IDGenVBox1" class="sapUiSmallMarginTop sapUiSmallMargin">
    <HBox id="_IDGenHBox" justifyContent="End">
        <Text id="_IDGenText10" text="Total Amount to Pay: " class="sapUiTinyMarginEnd"/>
        <ObjectNumber id="_IDGenObjectNumber"
            number="{summary>/totalGrossAmount}"
            unit="USD"
            emphasized="true"/>
    </HBox>
</VBox>

  <VBox id="_IDGenVBox2" class="sapUiSmallMargin">
            <Label id="_IDGenLabel" text="Comment (optional)" class="sapUiTinyMarginBottom"/>
            <TextArea
                id="descriptionInput"
                placeholder="Enter a comment..."
                width="100%"
                rows="2"/>
        </VBox>


 <buttons>

    <Button
      id="btnConfirm"
      text="Confirm"
      type="Accept"
      icon="sap-icon://accept"
      press=".onConfirmPO"/>

    <Button
      id="btnReject"
      text="Reject"
      type="Reject"
      icon="sap-icon://decline"
      press=".onRejectPO"/>

    <Button
      id="btnCancel"
      text="Cancel"
      icon="sap-icon://cancel"
      press=".onCloseDialog"/>

  </buttons>


    </Dialog>

</core:FragmentDefinition>